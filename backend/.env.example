# ─── Nexus Ultra Backend — environment variables ───────────────────────────
# Copy this file to .env and fill in values. Never commit .env to git.

# HTTP port the server listens on
PORT=3000

# API key required in the X-API-Key header for protected endpoints
API_KEY=changeme

# Persistence adapter to use: "memory" | "supabase" | "mongo"
STORE_ADAPTER=memory

# Supabase credentials (only needed when STORE_ADAPTER=supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-or-service-role-key

# MongoDB connection string (only needed when STORE_ADAPTER=mongo)
# MONGO_URI=mongodb://localhost:27017/nexus

# Logging level: error | warn | info | debug
LOG_LEVEL=info
