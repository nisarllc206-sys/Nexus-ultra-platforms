{
  "name": "nexus-ultra-platforms",
  "version": "1.0.0",
  "description": "AI Creator Website Ecosystem - Full-stack platform for AI-powered content creation",
  "main": "src/backend/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/backend/server.js",
    "dev": "nodemon src/backend/server.js",
    "build": "npm run lint && echo 'Build complete'",
    "lint": "eslint src/ --ext .js",
    "test": "jest --coverage",
    "deploy": "firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "docker:build": "docker build -t nexus-ultra-platforms .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase": "^10.12.2",
    "firebase-admin": "^12.2.0",
    "firebase-functions": "^6.0.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "stripe": "^16.1.0",
    "twilio": "^5.2.2",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^9.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "keywords": [
    "ai",
    "creator",
    "platform",
    "content-generation",
    "firebase",
    "stripe"
  ],
  "author": "Nexus Ultra Platforms",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/nexus-ultra-platforms.git"
  }
}
